FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    pkg-config \
    libfuse3-dev \
    fuse3 \
    && rm -rf /var/lib/apt/lists/*

RUN sed -i 's/#user_allow_other/user_allow_other/' /etc/fuse.conf 2>/dev/null || true

WORKDIR /opt/asofs

COPY . /opt/asofs/

RUN python3 -m venv /opt/asofs/venv && \
    /opt/asofs/venv/bin/python3 -m pip install --no-cache-dir -r requirements.txt && \
    /opt/asofs/venv/bin/python3 -m pip install --no-cache-dir -e .

RUN mkdir -p /mnt/asofs

COPY container/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV PATH="/opt/asofs/venv/bin:$PATH"
ENV ASOFS_MOUNTPOINT="/mnt/asofs"

ENTRYPOINT ["/entrypoint.sh"]
